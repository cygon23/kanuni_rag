# Copy to .env and fill in real values. Never commit .env.
# Grouped by the build phase (PROJECT_SPEC.md §14) that first consumes each
# variable. Phase 0 variables are read by apps/api/src/kanuni_api/config.py
# today; later-phase variables are documented now so the surface is visible
# up front, and are wired into config as their phase lands.

# ---- Phase 0: app / runtime -------------------------------------------
# development | staging | production
KANUNI_ENVIRONMENT=development
# debug | info | warning | error
KANUNI_LOG_LEVEL=info
# Comma-separated list of origins allowed to call the API (CORS).
KANUNI_CORS_ALLOWED_ORIGINS=http://localhost:3000
# Port the API binds to inside its container.
KANUNI_API_PORT=8000

# ---- Phase 0: database (Postgres 15 + pgvector) ------------------------
# Full DSN, e.g. postgresql://kanuni:kanuni@localhost:5432/kanuni
KANUNI_DATABASE_URL=postgresql://kanuni:kanuni@localhost:5432/kanuni
# Same DSN, unprefixed: dbmate (infra/migrations) reads the plain
# DATABASE_URL convention rather than an app-prefixed variable.
DATABASE_URL=postgresql://kanuni:kanuni@localhost:5432/kanuni
POSTGRES_USER=kanuni
POSTGRES_PASSWORD=kanuni
POSTGRES_DB=kanuni

# ---- Phase 1: ingestion / storage --------------------------------------
# Document storage is Supabase Storage (SupabaseStorage in both
# apps/api/src/kanuni_api/storage.py and
# apps/ingestion/src/kanuni_ingest/storage.py) via its plain REST API —
# no SDK dependency. Bare env vars (no KANUNI_ prefix), shared verbatim
# between apps/api and apps/ingestion, same convention as SENTRY_DSN
# below. The bucket is public (Kanuni's corpus is public regulatory
# text), so only writes (uploads) need the service-role key; reads go
# through the bucket's public URL. See docs/NEEDS.md for the exact
# bucket-creation step.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KANUNI_STORAGE_BUCKET=documents
# Maximum accepted upload size for POST /v1/admin/documents.
KANUNI_MAX_UPLOAD_SIZE_BYTES=104857600

# Admin API key used by the `kanuni ingest` CLI to call the admin API.
KANUNI_ADMIN_API_KEY=
KANUNI_ADMIN_API_BASE_URL=http://localhost:8000

# Postgres-backed job queue polling (no dedicated queue in v1 — see ADR
# 0005-adjacent tradeoff note in the Phase 1 handoff summary).
KANUNI_WORKER_POLL_INTERVAL_SECONDS=5

# OCR (Tesseract) and chunking (§7 stages 2-3).
KANUNI_OCR_LANGUAGES=eng+swa
KANUNI_CHUNK_TARGET_TOKENS=450
KANUNI_CHUNK_OVERLAP_TOKENS=60

# Metadata-extraction LLM call (§7 stage 4) — deliberately a small, cheap
# model, and a separate key/variable from Phase 3's future query-path
# GROQ_API_KEY below (same provider, may be the same secret value, kept as
# a distinct variable so the two call sites can be rate-limited or rotated
# independently).
KANUNI_METADATA_LLM_PROVIDER=groq
KANUNI_METADATA_LLM_MODEL=llama-3.1-8b-instant
KANUNI_GROQ_API_KEY=

# ---- Phase 2: retrieval (embeddings / reranker) ------------------------
KANUNI_EMBEDDING_MODEL=BAAI/bge-m3
KANUNI_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
KANUNI_DENSE_TOP_K=30
KANUNI_SPARSE_TOP_K=30
KANUNI_RRF_K=60
KANUNI_FUSION_TOP_K=20
KANUNI_RERANK_TOP_K=6

# ---- Phase 3: generation (LLM provider) --------------------------------
KANUNI_LLM_PROVIDER=groq
GROQ_API_KEY=
KANUNI_LLM_MODEL=llama-3.3-70b-versatile
KANUNI_LLM_FALLBACK_PROVIDER=
KANUNI_CONFIDENCE_REFUSE_THRESHOLD=0.30
KANUNI_CONFIDENCE_CAUTION_THRESHOLD=0.55

# ---- Phase 4: evaluation -------------------------------------------------
# Judge model for evals/run_answer_eval.py's faithfulness scoring — must
# differ from KANUNI_LLM_MODEL above (grading your own answers with the
# model that produced them inflates scores). Has a working default
# (Settings.eval_judge_llm_model); only set this to override it.
KANUNI_EVAL_JUDGE_LLM_MODEL=llama-3.1-8b-instant

# ---- Phase 5: frontend (apps/web) ---------------------------------------
# Server-only (never NEXT_PUBLIC_*): apps/web's Next.js Route Handlers
# (src/app/api/*/route.ts) proxy every browser request to the Kanuni API,
# attaching this key server-side, so the browser never sees an API key and
# apps/api's CORS config is irrelevant (same-origin from the browser).
KANUNI_API_BASE_URL=http://localhost:8000
# A `query`-scoped key (not the `ingest:admin`-scoped KANUNI_ADMIN_API_KEY
# above) — create one the same way, see docs/runbook.md's key-rotation
# section once it exists (Phase 6), or the API's admin key-creation path.
KANUNI_API_KEY=
# apps/web's own Supabase client (src/lib/supabase/{client,server}.ts —
# the standard @supabase/ssr pattern). NEXT_PUBLIC_* is safe here: the
# publishable key is meant to be public, unlike SUPABASE_SERVICE_ROLE_KEY
# above (server-only, apps/api/apps/ingestion, never apps/web). Not read
# by any feature yet — see client.ts's docstring. NOTE: apps/web reads
# its own apps/web/.env.local (Next.js convention), not this root .env —
# see that file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ---- Phase 6: observability / deploy ------------------------------------
KANUNI_OTEL_EXPORTER_OTLP_ENDPOINT=
# One GlitchTip (or real Sentry — same protocol) project's DSN, read
# verbatim (bare, no KANUNI_ prefix) by apps/api, apps/ingestion, and
# apps/web — see docs/NEEDS.md.
SENTRY_DSN=
# Not set automatically by deploy.yml on Hugging Face Spaces (unlike
# Fly's --env flag) — see docs/NEEDS.md's Hugging Face Spaces section.
# "dev" locally is the default (Settings.release_sha).
RELEASE_SHA=dev
# CI-only (GitHub Actions secrets/variables, not read by any app code
# directly) — see docs/NEEDS.md for what each fills.
HF_TOKEN=
HF_USERNAME=
VERCEL_TOKEN=
# apps/web's Sentry wiring (src/instrumentation.ts, src/instrumentation-
# client.ts). NEXT_PUBLIC_SENTRY_DSN is bundled into client JS — safe:
# Sentry DSNs are meant to be public (submit-only, not readable). On
# Vercel, NEXT_PUBLIC_RELEASE_SHA can be left unset — instrumentation.ts
# falls back to Vercel's own VERCEL_GIT_COMMIT_SHA automatically.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_RELEASE_SHA=
