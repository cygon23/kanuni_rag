# Copy to .env and fill in real values. Never commit .env.
# Grouped by the build phase (PROJECT_SPEC.md §14) that first consumes each
# variable. Phase 0 variables are read by apps/api/src/kanuni_api/config.py
# today; later-phase variables are documented now so the surface is visible
# up front, and are wired into config as their phase lands.

# ---- Phase 0: app / runtime -------------------------------------------
# development | staging | production
KANUNI_ENVIRONMENT=development
# debug | info | warning | error
KANUNI_LOG_LEVEL=info
# Comma-separated list of origins allowed to call the API (CORS).
KANUNI_CORS_ALLOWED_ORIGINS=http://localhost:3000
# Port the API binds to inside its container.
KANUNI_API_PORT=8000

# ---- Phase 0: database (Postgres 15 + pgvector) ------------------------
# Full DSN, e.g. postgresql://kanuni:kanuni@localhost:5432/kanuni
KANUNI_DATABASE_URL=postgresql://kanuni:kanuni@localhost:5432/kanuni
# Same DSN, unprefixed: dbmate (infra/migrations) reads the plain
# DATABASE_URL convention rather than an app-prefixed variable.
DATABASE_URL=postgresql://kanuni:kanuni@localhost:5432/kanuni
POSTGRES_USER=kanuni
POSTGRES_PASSWORD=kanuni
POSTGRES_DB=kanuni

# ---- Phase 1: ingestion / storage --------------------------------------
# Supabase Storage (or S3-compatible) bucket for original source documents.
KANUNI_STORAGE_BUCKET_URL=
KANUNI_STORAGE_ACCESS_KEY=
KANUNI_STORAGE_SECRET_KEY=
# Admin API key used by the `kanuni ingest` CLI to call the admin API.
KANUNI_ADMIN_API_KEY=

# ---- Phase 2: retrieval (embeddings / reranker) ------------------------
KANUNI_EMBEDDING_MODEL=BAAI/bge-m3
KANUNI_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
KANUNI_DENSE_TOP_K=30
KANUNI_SPARSE_TOP_K=30
KANUNI_RRF_K=60
KANUNI_FUSION_TOP_K=20
KANUNI_RERANK_TOP_K=6

# ---- Phase 3: generation (LLM provider) --------------------------------
KANUNI_LLM_PROVIDER=groq
GROQ_API_KEY=
KANUNI_LLM_MODEL=llama-3.3-70b-versatile
KANUNI_LLM_FALLBACK_PROVIDER=
KANUNI_CONFIDENCE_REFUSE_THRESHOLD=0.30
KANUNI_CONFIDENCE_CAUTION_THRESHOLD=0.55

# ---- Phase 4: evaluation -------------------------------------------------
# Judge model must differ from the answer model.
KANUNI_EVAL_JUDGE_MODEL=

# ---- Phase 6: observability / deploy ------------------------------------
KANUNI_OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
FLY_API_TOKEN=
VERCEL_TOKEN=
