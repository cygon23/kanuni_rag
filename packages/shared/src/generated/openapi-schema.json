        "description": "The kind of regulatory instrument a document is, per PROJECT_SPEC.md \u00a76."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestionJobSummary": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "document_id": {
            "type": "string",
            "format": "uuid",
            "title": "Document Id"
          },
          "stage": {
            "$ref": "#/components/schemas/PipelineStage"
          },
          "attempt_count": {
            "type": "integer",
            "title": "Attempt Count"
          },
          "error_details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Details"
          }
        },
        "type": "object",
        "required": [
          "id",
          "document_id",
          "stage",
          "attempt_count",
          "error_details"
        ],
        "title": "IngestionJobSummary",
        "description": "An `ingestion_jobs` row, as exposed by the admin failed-jobs endpoint."
      },
      "LivenessResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
