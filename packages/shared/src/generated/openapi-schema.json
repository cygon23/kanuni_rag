            "title": "Document Id"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "section_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Section Ref"
          },
          "page_start": {
            "type": "integer",
            "title": "Page Start"
          },
          "page_end": {
            "type": "integer",
            "title": "Page End"
          },
          "dense_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Dense Score"
          },
          "sparse_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
